# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://compliance:compliance@localhost:5432/compliance

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── WorkOS (https://workos.com/docs/sso/guide) ──────────────────────────────
# Server-side secret — never expose to browser
WORKOS_API_KEY=sk_test_REPLACE_ME
WORKOS_CLIENT_ID=client_REPLACE_ME
# Must match a redirect URI registered in WorkOS dashboard
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
# Public — safe to expose to browser
NEXT_PUBLIC_WORKOS_CLIENT_ID=client_REPLACE_ME

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# S3 bucket for evidence files
AWS_S3_BUCKET=compliance-evidence-local
# KMS key for SSE-KMS encryption of evidence objects
AWS_KMS_KEY_ARN=arn:aws:kms:us-east-1:000000000000:key/00000000-0000-0000-0000-000000000000

# ─── LocalStack (local dev only) ──────────────────────────────────────────────
# Overrides AWS endpoint — LocalStack emulates S3, KMS, Secrets Manager
AWS_ENDPOINT_URL=http://localhost:4566
# LocalStack uses these dummy credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─── Secrets Manager ──────────────────────────────────────────────────────────
# Leave unset in production — only used to point at LocalStack in dev
SECRETS_MANAGER_ENDPOINT=http://localhost:4566

# ─── OpenAI (Phase 3 — drafting only, not used in Phase 1/2) ─────────────────
# AI drafting is disabled gracefully if key is not set (returns HTTP 503)
OPENAI_API_KEY=sk-REPLACE_ME

# ─── Resend (Phase 4 — email notifications, disabled gracefully if not set) ───
RESEND_API_KEY=re_REPLACE_ME
APP_DOMAIN=localhost

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
# Internal API URL used by server-side Next.js fetches
API_URL=http://localhost:8080
# Public API URL used by browser
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Cookie / Session ─────────────────────────────────────────────────────────
# 32-byte hex secret for session cookie signing
COOKIE_SECRET=change_me_to_a_32_byte_random_hex_value_in_production
